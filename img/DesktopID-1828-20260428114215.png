<div class="sakura-wrap" id="fx-overlay"></div>

<style>
/* === LAYER GLOBAL === */
.sakura-wrap{
  position:fixed;
  inset:0;
  pointer-events:none;
  overflow:hidden;
  z-index:9999;
}

/* === BUNGA SAKURA === */
.sakura{
  position:absolute;
  top:-10vh;
  width:22px;
  height:22px;

  background-repeat:no-repeat;
  background-size:contain;
  background-position:center;

  /* SVG bunga sakura pink */
  background-image:url("data:image/svg+xml;utf8,\
  <svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'>\
  <g fill='%23ff69b4'>\
  <circle cx='50' cy='20' r='20'/>\
  <circle cx='80' cy='50' r='20'/>\
  <circle cx='50' cy='80' r='20'/>\
  <circle cx='20' cy='50' r='20'/>\
  <circle cx='50' cy='50' r='15' fill='%23ffd6eb'/>\
  </g>\
  </svg>");

  filter:drop-shadow(0 0 8px #ff8fcf);
  opacity:.95;

  animation:
  sakura-fall var(--dur,12s) linear var(--delay,0s) infinite,
  sakura-sway var(--sway,6s) ease-in-out var(--delay,0s) infinite alternate,
  sakura-rotate var(--spin,6s) linear infinite;
}

.sakura.-sm{
  width:14px;
  height:14px;
}

.sakura.-lg{
  width:32px;
  height:32px;
}

/* jatuh */
@keyframes sakura-fall{
  to{
    transform:translateY(110vh);
  }
}

/* goyang */
@keyframes sakura-sway{
  from{margin-left:-20px;}
  to{margin-left:20px;}
}

/* muter */
@keyframes sakura-rotate{
  from{rotate:0deg;}
  to{rotate:360deg;}
}

/* === KEMBANG API PINK === */
.firework{
  position:absolute;
  width:6px;
  height:6px;
  border-radius:50%;
  background:radial-gradient(circle,#fff 20%,#ff7ac8 40%,transparent 70%);
  opacity:0;
  animation:firework 1.8s ease-out forwards;
}

.firework::before{
  content:"";
  position:absolute;
  inset:0;
  box-shadow:
  0 -25px #ff9ed9,
  18px -18px #ff9ed9,
  25px 0 #ff9ed9,
  18px 18px #ff9ed9,
  0 25px #ff9ed9,
  -18px 18px #ff9ed9,
  -25px 0 #ff9ed9,
  -18px -18px #ff9ed9;
}

@keyframes firework{
  0%{transform:translate(-50%,-50%) scale(.2);opacity:0}
  20%{opacity:1}
  60%{transform:translate(-50%,-50%) scale(1.3);opacity:1}
  100%{transform:translate(-50%,-50%) scale(1.8);opacity:0}
}

@media (prefers-reduced-motion:reduce){
  .sakura,.firework{animation:none!important}
}
</style>

<script>
(function(){

const wrap=document.getElementById("fx-overlay");
if(!wrap) return;

/* GENERATE SAKURA */
for(let i=0;i<40;i++){

const s=document.createElement("span");
s.className="sakura";

if(Math.random()<0.25) s.classList.add("-sm");
if(Math.random()>0.8) s.classList.add("-lg");

s.style.left=Math.random()*100+"%";
s.style.setProperty("--dur",(10+Math.random()*10)+"s");
s.style.setProperty("--delay",(Math.random()*8)+"s");
s.style.setProperty("--sway",(4+Math.random()*4)+"s");
s.style.setProperty("--spin",(4+Math.random()*6)+"s");

wrap.appendChild(s);
}

/* FIREWORK */
function spawnFirework(){

const fw=document.createElement("span");
fw.className="firework";

fw.style.left=(10+Math.random()*80)+"%";
fw.style.top=(10+Math.random()*30)+"%";

wrap.appendChild(fw);

setTimeout(()=>fw.remove(),1900);
}

spawnFirework();
setInterval(spawnFirework,1700);

})();
</script>
